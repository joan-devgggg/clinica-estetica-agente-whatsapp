# Copia este archivo como .env y rellena los valores

OPENAI_API_KEY=sk-proj-...

# Supabase (base de datos y dashboard)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Organizaciones (multi-tenant)
# UUID de cada org (de los seeds SQL)
SANREMO_ORG_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890
SANTE_ORG_ID=b2c3d4e5-f6a7-8901-bcde-f12345678901

# Número WhatsApp de cada org (sin + ni espacios)
SANREMO_WA_PHONE=34667474233
SANTE_WA_PHONE=34641029104

# Fallback: org por defecto si no se especifica (backward compat)
ORGANIZATION_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# Dashboard (protege la API REST interna)
# Genera un secreto fuerte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_API_SECRET=cambia_esto_por_un_secreto_seguro

# Telegram (panel de administración — mismo bot para ambas orgs)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# IDs de admins por defecto (se complementa con config.telegram_admins en la BD por org)
TELEGRAM_ALLOWED_USERS=123456789,987654321

PORT=3000
