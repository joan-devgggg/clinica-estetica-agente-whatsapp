# Copia este archivo como .env y rellena los valores

OPENAI_API_KEY=sk-proj-...

# Supabase (base de datos y dashboard)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# UUID de la organización (del seed 002_seed.sql — no cambiar salvo multi-tenant)
ORGANIZATION_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# Meta / Instagram Lead Ads
META_WEBHOOK_VERIFY_TOKEN=tu_token_verificacion
META_APP_SECRET=tu_app_secret           # Obligatorio — el webhook rechaza peticiones sin firma HMAC válida

# Dashboard (protege la API REST interna)
# Genera un secreto fuerte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_API_SECRET=cambia_esto_por_un_secreto_seguro

# Telegram (panel de administración)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Google Reviews
GOOGLE_REVIEW_LINK=https://g.page/r/...

PORT=3000
